# PyScreen Configuration
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Gemini model to use (default: gemini-2.5-flash)
# Options: gemini-2.5-flash, gemini-3.5-flash, gemini-2.0-flash
GEMINI_MODEL=gemini-2.5-flash

# Backend: "gemini" (cloud API) or "ollama" (local LLM)
LLM_BACKEND=gemini

# Ollama settings (only used when LLM_BACKEND=ollama)
OLLAMA_MODEL=gemma3:27b
OLLAMA_HOST=http://localhost:11434
