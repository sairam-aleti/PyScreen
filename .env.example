# PyScreen Configuration
# ======================

# Backend: "gemini" (cloud API), "ollama" (local Ollama), or "llama_cpp" (local llama.cpp)
LLM_BACKEND=llama_cpp

# --- Gemini Settings (only used when LLM_BACKEND=gemini) ---
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Ollama Settings (only used when LLM_BACKEND=ollama) ---
OLLAMA_MODEL=gemma3:27b
OLLAMA_HOST=http://localhost:11434

# --- llama.cpp Settings (only used when LLM_BACKEND=llama_cpp) ---
LLAMA_CPP_MODEL=Gemma 4 31B QAT
LLAMA_CPP_HOST=http://localhost:8001
LLAMA_CPP_API_KEY=pyscreen_lab_2026
